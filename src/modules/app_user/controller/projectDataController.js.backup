// Get project links data
// REFACTORED: Now uses service layer - Phase 2 Refactoring
// Original logic moved to ProjectLinksService.getProjectLinks()
export const getProjectLinks = async (req, res) => {
  try {
    const { id: projectId } = req.params;
    const { page = 1, limit = 50, link_type, search } = req.query;

    // TODO: REMOVE_AFTER_REFACTOR - Original controller logic below
    // All business logic moved to ProjectLinksService.getProjectLinks()
    // This maintains EXACT same API behavior while cleaning up controller
    
    const result = await ProjectLinksService.getProjectLinks(req.user._id, projectId, req.query);
    
    // Return EXACT same response format as before
    return res.json(result);

  } catch (error) {
    console.error('Error getting project links:', error);
    
    // Handle custom errors from service (maintain exact same error responses)
    if (error.statusCode && error.response) {
      return res.status(error.statusCode).json(error.response);
    }
    
    // Default error response (EXACT same as original)
    res.status(500).json({
      success: false,
      message: 'Failed to get project links',
      error: error.message
    });
  }
};




